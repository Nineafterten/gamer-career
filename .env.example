# Copy to .env for local `netlify dev`, and set the same var in the Netlify
# dashboard (Site settings → Environment variables) for the deployed site.
# Never commit the real value — .env is gitignored.
#
# Get a free key at https://xbl.io and authorize it with your Xbox account.
OPENXBL_KEY=

# IGDB public scores (optional): create a free app at
# https://dev.twitch.tv/console/apps for a Client ID + Secret. Powers the gamer
# rating filled by "Fetch details". Without these, scores fall back to RAWG.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
